[Unit]
Description=DayTrade Dash React Dashboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/pai-server/trading/dashboard
ExecStart=/home/pai-server/trading/dashboard/node_modules/.bin/vite --host 0.0.0.0 --port 3456
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
